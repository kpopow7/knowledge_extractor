# Copy to ".env" and adjust. Loaded automatically by rag_storage (see README).
# Values already set in your shell or container take precedence over this file.

# --- Core paths ---
# RAG_STORAGE_ROOT=

# --- PostgreSQL + pgvector (omit for SQLite-only local dev) ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/rag
# RAG_PG_VECTOR_DIM=1536
# RAG_PG_DISABLE_HNSW=0
# When DATABASE_URL is set, tenant usage quotas and embedding cache use Postgres (not local SQLite).

# --- Object storage (optional; MinIO/S3/R2) ---
# RAG_S3_BUCKET=
# RAG_S3_PREFIX=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=
# AWS_REGION=us-east-1

# --- OpenAI (embeddings, chat, ingest) ---
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini
# RAG_INDEX_FAKE_EMBEDDINGS=0
# RAG_INDEX_FAKE_DIMS=256
# RAG_EMBEDDING_CACHE=0
# With DATABASE_URL, cache rows live in table embedding_cache (shared across API/workers).

# --- Reranking ---
# COHERE_API_KEY=
# COHERE_RERANK_MODEL=rerank-english-v3.0
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- HTTP API ---
# RAG_API_HOST=127.0.0.1
# RAG_API_PORT=8000
# RAG_API_KEYS=
# RAG_API_CORS_ORIGINS=
# RAG_API_RATE_LIMIT=120/minute
# RAG_API_RATE_LIMIT_INGEST=30/minute
# RAG_API_LOG_LEVEL=INFO

# --- Background jobs ---
# REDIS_URL=redis://localhost:6379/0
